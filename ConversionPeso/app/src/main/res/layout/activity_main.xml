<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp"
            android:paddingTop="48dp"
            android:paddingBottom="32dp">

            <!-- Título -->
            <TextView
                android:id="@+id/Titulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ConversionPeso"
                android:textSize="26sp"
                android:textStyle="normal"
                android:textColor="#333333"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <!-- Input -->
            <TextView
                android:id="@+id/LblValor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Valor"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/input"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="0.00"
                android:inputType="numberDecimal"
                android:textSize="16sp"
                android:padding="12dp"
                android:layout_marginBottom="28dp" />

            <!-- Unidad origen -->

            <TextView
                android:id="@+id/lblConvertirDe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Convertir de"
                android:textColor="#666666"
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/spinnerDe"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="24dp" />

            <!-- Unidad destino -->
            <TextView
                android:id="@+id/lblConvertirA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Convertir a"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinner2"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="36dp" />

            <!-- Botón -->
            <Button
                android:id="@+id/btnConvertir"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="36dp"
                android:background="#3A3A3A"
                android:text="Convertir"
                android:textAllCaps="false"
                android:textSize="15sp" />

            <!-- Resultado -->

            <TextView
                android:id="@+id/lblResultado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Resultado"
                android:textColor="#999999"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_marginBottom="48dp" />

            <!-- Footer -->
            <TextView
                android:id="@+id/footer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Gloria Moreno · Jonathan Gómez · Juan García · Miguel Caballero"
                android:textColor="#BBBBBB"
                android:textSize="11sp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>